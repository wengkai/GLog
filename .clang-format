# Base style to build upon
BasedOnStyle: LLVM

# Indentation width (usually 2 or 4)
IndentWidth: 4

# Maximum characters per line before wrapping
ColumnLimit: 100

# Where do the braces go?
# Attach: same line | Linux: new line
BreakBeforeBraces: Attach

# Sort includes alphabetically
SortIncludes: true
IncludeCategories:
  - Regex:           '^<QtTest>'
    Priority:        -1
  - Regex:           '^<.*'
    Priority:        1
  - Regex:           '.*'
    Priority:        2

# Allow putting short 'if' statements on one line
AllowShortIfStatementsOnASingleLine: true
